ADMIN_PASSWORD=change-me-to-a-strong-password

# Admin panel URL — use the EXACT domain you add in Vercel → Settings → Domains
# Use HYPHEN (-), not dot: harvcioushacks-admin.vercel.app
NEXT_PUBLIC_ADMIN_URL=https://harvcioushacks-admin.vercel.app

# Optional: extra admin hostnames (comma-separated, must match Vercel Domains)
ADMIN_HOSTS=harvcioushacks-admin.vercel.app

# Auto-set by Vercel when you create a Blob store (Storage → Blob → Connect to project)
# BLOB_READ_WRITE_TOKEN=
